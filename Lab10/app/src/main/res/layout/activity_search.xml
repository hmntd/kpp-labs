<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/search"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SearchActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <AutoCompleteTextView
            android:id="@+id/acBrand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_brand"
            android:minHeight="48dp" />

        <AutoCompleteTextView
            android:id="@+id/acModel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_model"
            android:minHeight="48dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_age"
            android:layout_marginTop="16dp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <EditText
                android:id="@+id/etYearFrom"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:hint="@string/start"
                android:inputType="number"
                android:autofillHints="startYear"
                android:minHeight="48dp"/>

            <EditText
                android:id="@+id/etYearTo"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:hint="@string/finish"
                android:inputType="number"
                android:autofillHints="endYear"
                android:minHeight="48dp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>

        <com.google.android.material.slider.RangeSlider
            android:id="@+id/yearSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:valueFrom="1980"
            android:valueTo="2026" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/label_price" android:layout_marginTop="10dp"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Spinner android:id="@+id/spCostFrom" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:minHeight="48dp" />
            <Spinner android:id="@+id/spCostTo" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:minHeight="48dp" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/reset"
                android:backgroundTint="@android:color/darker_gray"
                style="?android:attr/buttonBarButtonStyle"/>

            <Button
                android:id="@+id/btnMatches"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="@string/matches_count"
                android:enabled="false"
                style="?android:attr/buttonBarButtonStyle"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>